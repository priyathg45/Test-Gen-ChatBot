FLASK_ENV=development
FLASK_APP=src/api/app.py
FLASK_DEBUG=True
DATA_PATH=data/aluminum_products.csv
MODEL_NAME=all-MiniLM-L6-v2
TOP_K_RESULTS=3
SIMILARITY_THRESHOLD=0.3

# PDF: if text extraction yields fewer chars, try OCR (scanned PDFs). Requires Tesseract + poppler.
# PDF_MIN_TEXT_CHARS=100
# PDF_OCR_MAX_PAGES=50

# Ollama (local LLM) for document QA – run: ollama run llama3.2
# USE_OLLAMA_FOR_DOCUMENTS=true
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2
